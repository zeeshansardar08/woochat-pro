# Ignore OS files
.DS_Store
Thumbs.db

# Ignore logs
*.log

# Ignore backup/editor files
*.bak
*.swp
*.tmp

# Local dev planning doc — never ship in the repo
WooChat-Master-Development-Prompt.md

# Ignore PHP tooling
vendor/
composer.lock
phpunit.xml
.phpunit.result.cache
phpcs.xml
.phpcs.cache

# Ignore Node tooling — the plugin has no build step and ships hand-written
# JS, so package.json (and its lockfile + install dir) are dev-only artifacts
# that should never enter the repo.
node_modules/
package.json
package-lock.json

# Freemius caches the plugin icon here at runtime (downloaded on admin load),
# so it is a generated artifact, not source.
freemius/assets/img/zignites-chat.png